# Application settings — override any value via environment variable or .env file

# --- Application ---
APP_NAME="Contract Analysis AI"
DEBUG=false

# --- Model ---
# Name of the pretrained HuggingFace model to fine-tune
BASE_MODEL_NAME=distilbert-base-uncased
MAX_LENGTH=512

# --- Training ---
DATASET_NAME=alisha4walunj/quad_ledgar_merged_dataset
TEXT_COLUMN=text
LABEL_COLUMN=label
NUM_TRAIN_EPOCHS=3
PER_DEVICE_TRAIN_BATCH_SIZE=16
LEARNING_RATE=2e-5
TEST_SIZE=0.15

# --- API ---
API_PREFIX=/api/v1
